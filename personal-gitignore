#!/usr/bin/env python3

import argparse
import os
import shlex
import shutil
import stat
import subprocess
import sys
from pathlib import Path


def run_git(args, cwd=None, env=None):
    completed = subprocess.run(
        ["git", *args],
        cwd=cwd,
        env=env,
        check=False,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        stderr = completed.stderr.strip() or completed.stdout.strip() or "git command failed"
        raise RuntimeError(stderr)
    return completed.stdout.strip()


def resolve_local_ignore_file(cwd, env):
    repo_root = run_git(["rev-parse", "--show-toplevel"], cwd=cwd, env=env)
    return Path(repo_root) / ".git" / "info" / "exclude"


def resolve_global_ignore_file(env):
    completed = subprocess.run(
        ["git", "config", "--global", "--get", "core.excludesfile"],
        env=env,
        check=False,
        capture_output=True,
        text=True,
    )
    configured = completed.stdout.strip() if completed.returncode == 0 else ""
    if configured:
        return Path(os.path.expanduser(configured))

    default_path = Path(os.path.expanduser("~/.gitignore_global"))
    run_git(["config", "--global", "core.excludesfile", str(default_path)], env=env)
    return default_path


def ensure_file(path):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.touch(exist_ok=True)


def read_patterns(path):
    if not path.exists():
        return []
    return path.read_text(encoding="utf-8").splitlines()


def write_patterns(path, patterns):
    content = "\n".join(patterns)
    if content:
        content += "\n"
    path.write_text(content, encoding="utf-8")


def open_editor(path, env):
    editor = env.get("EDITOR") or env.get("VISUAL")
    if not editor:
        try:
            editor = run_git(["var", "GIT_EDITOR"], env=env)
        except RuntimeError:
            editor = ""

    if not editor:
        raise RuntimeError("No editor found. Set EDITOR or VISUAL.")

    cmd = shlex.split(editor) + [str(path)]
    completed = subprocess.run(cmd, env=env, check=False)
    if completed.returncode != 0:
        raise RuntimeError(f"Editor exited with status {completed.returncode}")


def install_cli(bin_dir=None):
    target_dir = Path(os.path.expanduser(bin_dir)) if bin_dir else Path(os.path.expanduser("~/.local/bin"))
    target_dir.mkdir(parents=True, exist_ok=True)

    source_dir = Path(__file__).resolve().parent
    entries = {
        "personal-gitignore": source_dir / "personal-gitignore",
        "pgi": source_dir / "pgi",
    }

    installed = []
    for name, source in entries.items():
        if not source.exists():
            raise RuntimeError(f"Missing source executable: {source}")
        destination = target_dir / name
        shutil.copy2(source, destination)
        mode = destination.stat().st_mode
        destination.chmod(mode | stat.S_IXUSR)
        installed.append(destination)

    for path in installed:
        print(path)


def parse_args(argv):
    parser = argparse.ArgumentParser(
        description="Manage personal gitignore rules locally (.git/info/exclude) or globally.",
    )
    scope = parser.add_mutually_exclusive_group()
    scope.add_argument("--local", action="store_true", help="Use repository-local personal gitignore")
    scope.add_argument("--global", dest="global_scope", action="store_true", help="Use global personal gitignore")

    parser.add_argument(
        "command",
        choices=["setup", "install", "list", "add", "remove", "clear", "edit"],
        help="Inline mode: list/add/remove/clear. Editor mode: edit.",
    )
    parser.add_argument("pattern", nargs="?", help="Pattern used by add/remove commands")
    parser.add_argument("--bin-dir", help="Install location for the install command (default: ~/.local/bin)")
    return parser.parse_args(argv)


def main(argv=None):
    args = parse_args(argv or sys.argv[1:])
    env = os.environ.copy()
    cwd = os.getcwd()

    try:
        if args.command == "install":
            install_cli(args.bin_dir)
            return 0
        if args.bin_dir:
            raise RuntimeError("--bin-dir can only be used with the install command")

        ignore_file = resolve_global_ignore_file(env) if args.global_scope else resolve_local_ignore_file(cwd, env)
        ensure_file(ignore_file)

        if args.command == "setup":
            print(ignore_file)
            return 0

        if args.command == "edit":
            open_editor(ignore_file, env)
            return 0

        patterns = read_patterns(ignore_file)

        if args.command == "list":
            for line in patterns:
                print(line)
            return 0

        if args.command in {"add", "remove"} and not args.pattern:
            raise RuntimeError(f"'{args.command}' requires a pattern")

        if args.command == "add":
            if args.pattern not in patterns:
                patterns.append(args.pattern)
                write_patterns(ignore_file, patterns)
            return 0

        if args.command == "remove":
            updated = [line for line in patterns if line != args.pattern]
            write_patterns(ignore_file, updated)
            return 0

        if args.command == "clear":
            write_patterns(ignore_file, [])
            return 0
    except RuntimeError as error:
        print(f"Error: {error}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
